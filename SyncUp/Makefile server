# Ce Makefile permet de compiler uniquement la partie serveur du projet.

# Cible exécutée par défaut lorsque l'on tape la commande "make".
# Elle compile tous les fichiers sources du serveur
# puis génère un exécutable nommé "server".
# Les options -I et -L indiquent à gcc où trouver les fichiers
# d'en-tête (.h) et les bibliothèques de PostgreSQL et OpenSSL.
# Ces chemins correspondent à l'installation via MSYS2
# (pacman -S mingw-w64-ucrt-x86_64-postgresql), compatible
# nativement avec gcc. Cette commande doit être lancée depuis
# un terminal MSYS2 UCRT64, pas PowerShell classique.
# -lpq      : bibliothèque PostgreSQL, utilisée par db.c
# -lpthread : gestion des threads, utilisée par thread_handler.c
# -lssl -lcrypto : bibliothèques OpenSSL, utilisées par crypto.c
#                  pour le hachage SHA-256 et la génération du sel

all:
	gcc -I/ucrt64/include -L/ucrt64/lib -o server server/main_server.c server/socket_server.c server/thread_handler.c server/auth.c server/channel_manager.c server/crypto.c server/notification_system.c server/db.c -lpq -lpthread -lssl -lcrypto

# Supprime l'exécutable généré lors de la compilation.
# Cette cible permet de nettoyer le répertoire de travail.

clean:
	rm -f server